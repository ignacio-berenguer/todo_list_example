# Database (paths are relative to the backend/ directory)
DATABASE_URL=sqlite:///../db/todo_list.db
SCHEMA_PATH=../db/schema.sql

# Logging
LOG_LEVEL=INFO
LOG_FILE=../logs/task_manager_backend.log
LOG_TO_CONSOLE=True

# Clerk authentication
# These are OPTIONAL: leave empty to let the backend boot without Clerk credentials.
# When empty, every authenticated request returns HTTP 503 ("Clerk no configurado").
CLERK_JWKS_URL=
CLERK_ISSUER=
# Optional: only set if your Clerk app issues an `aud` claim.
CLERK_AUDIENCE=

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173

# uvicorn bind
HOST=0.0.0.0
PORT=8000
